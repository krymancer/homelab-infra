# Copy this to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored — never commit it

proxmox_api_token_id     = "terraform@pam!terraform"
proxmox_api_token_secret = "your-token-secret-here"

ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIF7Q95691WXu2MwzknbezIzUMNuL7bd8cP9sGfe5u+Ec "

ci_password = "*vBsHTU13$YfBvU^f5x4YT3m"

k3s_vm = {
  vmid    = 200
  name    = "k3s"
  cores   = 4
  memory  = 8192
  disk    = "40G"
  storage = "local-lvm"   # check your Proxmox storage name
  ip      = "192.168.0.20/24"
  gateway = "192.168.0.1" # your router IP
}

# Tailscale pre-auth key. Create one-off at:
#   https://login.tailscale.com/admin/settings/keys
# Recommended: reusable=false, ephemeral=false, expiry 24h, tag:dev
tailscale_auth_key = "tskey-auth-XXXXXXXXXXXX"

dev_lxc = {
  vmid     = 201
  name     = "dev"
  cores    = 2
  memory   = 2048
  disk     = "20G"
  storage  = "local-lvm"
  ip       = "192.168.0.21/24"
  gateway  = "192.168.0.1"
  # Run `pveam list local` on PVE to confirm exact filename.
  # Download if missing: `pveam update && pveam download local debian-12-standard_12.7-1_amd64.tar.zst`
  template = "local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst"
}
